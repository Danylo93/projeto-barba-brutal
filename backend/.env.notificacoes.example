# Notificações por e-mail (opcional).
# Sem estas variáveis, o agendamento funciona normalmente e o envio é apenas
# registrado em log (nenhum e-mail é enviado).
SMTP_HOST=smtp.seuprovedor.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=usuario@seuprovedor.com
SMTP_PASS=sua-senha-ou-app-password
SMTP_FROM=no-reply@suabarbearia.com
